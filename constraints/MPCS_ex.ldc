set RXEQ_ALGO_DEC 7
set GEN12_ENA_POST_A1A2 "DISABLED"
set GEN12_ENA_PREA0 "DISABLED"
set GEN12_ENA_POST_A0 "DISABLED"
set GEN3_ENA_POST_A1A2 "DISABLED"
set GEN3_ENA_PREA0 "DISABLED"
set GEN3_ENA_POST_A0 "DISABLED"
set PCIELL_MODESEL 5
set FIFO_AF 12
set TX_FIFO_AF "0b1100"
set FIFO_AE 4
